# Agent Blue Accounting - Environment Configuration
# Development-only values. Do NOT commit real credentials.
# Copy this file to .env and adjust as needed.

# Application
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL (development-only credentials)
DB_HOST=localhost
DB_PORT=5433
DB_USER=agentblue
DB_PASSWORD=agentblue
DB_NAME=agentblue_dev

# QuickBooks Online OAuth (optional — required for QuickBooks integration)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
